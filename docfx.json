{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [],
  "build": {
    "content": [
      {
        "files": [
          "**/*.md",
          "**/toc.yml"
        ],
        "exclude": [
          "**/README.md"
        ],
        "src": "docs"
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ],
        "src": "docs"
      }
    ],
    "output": "_site",
    "globalMetadata": {
      "_appName": "Stash",
      "_appTitle": "Stash",
      "_appFooter": "Stash docs · powered by DocFX",
      "_enableSearch": true,
      "_disableContribution": true
    },
    "template": [
      "default",
      "modern"
    ]
  }
}
